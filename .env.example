# Appwrite Configuration
# Get these values from your Appwrite Console (https://cloud.appwrite.io)

# Appwrite API endpoint (use cloud.appwrite.io or your self-hosted instance)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite Project ID (found in Project Settings)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# Your Appwrite Database ID (found in Databases section)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=

# Appwrite API Key with server permissions (create in Project Settings > API Keys)
# Required permissions: documents.read, documents.write
APPWRITE_API_KEY=

# DeepSeek API Key (OpenAI-compatible, required for all AI features)
# The app uses DeepSeek exclusively — no Anthropic key needed
# Get your key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Brave Search API (Optional - for real-world market data in AI analysis)
# Get your free API key at: https://brave.com/search/api/
# Free tier: 2,000 queries/month
BRAVE_SEARCH_API_KEY=

# Application URL (used for OAuth redirects and absolute links)
# Set this to your production domain or localhost during development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel URL (auto-set on Vercel deployments, used as fallback for OAuth)
VERCEL_URL=

